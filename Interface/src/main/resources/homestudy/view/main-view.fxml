<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" prefHeight="720.0" prefWidth="960.0" style="-fx-background-color: white;" xmlns="http://javafx.com/fxml/1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="homestudy.view.MainViewController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="72.0" spacing="16.0" style="-fx-background-color: white; -fx-border-color: transparent transparent #d6d6d6 transparent; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <Button text="&#9776;" onAction="#toggleSidebar" prefHeight="40.0" prefWidth="48.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #777; -fx-border-radius: 8; -fx-text-fill: #222; -fx-font-size: 20px; -fx-font-weight: bold;" />
            <HBox alignment="CENTER" spacing="4.0">
                <Label text="Home" style="-fx-text-fill: #d92828;">
                    <font>
                        <Font name="System" size="28.0" />
                    </font>
                </Label>
                <Label text="Study" style="-fx-text-fill: #8a5318;">
                    <font>
                        <Font name="System" size="28.0" />
                    </font>
                </Label>
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <TextField promptText="Pesquisar imoveis, bairros ou valores" prefHeight="40.0" prefWidth="380.0" style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #777; -fx-border-width: 1.5; -fx-font-size: 14px;" />
            <Button text="Filtros" onAction="#showPropertySearch" prefHeight="40.0" prefWidth="92.0" style="-fx-background-color: #d92828; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-weight: bold;" />
        </HBox>
    </top>
    <left>
        <VBox fx:id="sidebar" prefWidth="0.0" style="-fx-background-color: #2d2d2d;" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="56.0" prefWidth="200.0" style="-fx-background-color: #1f1f1f;">
                    <padding>
                        <Insets left="10.0" right="10.0" />
                    </padding>
                    <Button text="&#9776;" onAction="#toggleSidebar" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label text="Opcoes" textFill="WHITE" HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                </HBox>
                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                    <Button mnemonicParsing="false" onAction="#showHome" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #d92828; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-weight: bold;" text="Principal" />
                    <Button fx:id="mapButton" mnemonicParsing="false" onAction="#showMap" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #555; -fx-background-radius: 8; -fx-text-fill: white;" text="Radar" />
                    <Button fx:id="searchButton" mnemonicParsing="false" onAction="#showPropertySearch" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #555; -fx-background-radius: 8; -fx-text-fill: white;" text="Filtros" />
                    <Button fx:id="profileButton" mnemonicParsing="false" onAction="#showProfile" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #555; -fx-background-radius: 8; -fx-text-fill: white;" text="Perfil" />
                </VBox>
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: white;" BorderPane.alignment="CENTER">
            <children>
                <Label text="HomeStudy" />
            </children>
        </StackPane>
    </center>
</BorderPane>
