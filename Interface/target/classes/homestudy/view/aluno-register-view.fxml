<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/fxml/1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="homestudy.view.AlunoRegisterViewController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
    </padding>

    <Label text="Cadastro de Aluno">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <VBox spacing="5.0">
        <Label text="Nome Completo:" />
        <TextField fx:id="nomeField" promptText="Digite seu nome" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="E-mail:" />
        <TextField fx:id="emailField" promptText="Digite seu e-mail" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Telefone:" />
        <TextField fx:id="telefoneField" promptText="Digite seu telefone (opcional)" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Senha:" />
        <PasswordField fx:id="senhaField" promptText="Crie uma senha" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Data de Nascimento (DD/MM/AAAA):" />
        <TextField fx:id="dataNascimentoField" promptText="Ex: 01/01/2000" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Curso:" />
        <TextField fx:id="cursoField" promptText="Digite seu curso" />
    </VBox>

    <VBox spacing="5.0">
        <Label text="Período/Semestre:" />
        <TextField fx:id="periodoField" promptText="Ex: 3º Semestre" />
    </VBox>

    <Button text="Cadastrar" onAction="#handleRegister" maxWidth="Infinity" defaultButton="true"/>
    <Button text="Voltar" onAction="#handleBackButton" maxWidth="Infinity"/>

    <Label fx:id="labelMensagem" textFill="RED" wrapText="true" />

</VBox>
