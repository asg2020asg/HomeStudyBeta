<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="720.0" prefWidth="960.0" spacing="24.0" style="-fx-background-color: white;" xmlns="http://javafx.com/fxml/1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="homestudy.view.InitialViewController">
    <padding>
        <Insets bottom="28.0" left="44.0" right="44.0" top="28.0"/>
    </padding>

    <HBox alignment="CENTER" spacing="10.0">
        <Label text="Bem vindo ao" style="-fx-text-fill: #222;">
            <font>
                <Font name="System" size="52.0" />
            </font>
        </Label>
        <Label text="Home" style="-fx-text-fill: #d92828;">
            <font>
                <Font name="System" size="52.0" />
            </font>
        </Label>
        <Label text="Study" style="-fx-text-fill: #8a5318;">
            <font>
                <Font name="System" size="52.0" />
            </font>
        </Label>
    </HBox>

    <GridPane alignment="CENTER" hgap="42.0" vgap="34.0">
        <VBox prefHeight="140.0" prefWidth="220.0" style="-fx-background-color: linear-gradient(to bottom right, #d7ecff, #c9a986); -fx-border-color: #dddddd;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <VBox prefHeight="140.0" prefWidth="220.0" style="-fx-background-color: linear-gradient(to bottom right, #e7eef2, #8f8f8f); -fx-border-color: #dddddd;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <VBox prefHeight="140.0" prefWidth="220.0" style="-fx-background-color: linear-gradient(to bottom right, #9fd2ff, #d7b68d); -fx-border-color: #dddddd;" GridPane.columnIndex="2" GridPane.rowIndex="0" />
        <VBox prefHeight="140.0" prefWidth="220.0" style="-fx-background-color: linear-gradient(to bottom right, #f1f1f1, #a9554b); -fx-border-color: #dddddd;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <VBox prefHeight="140.0" prefWidth="220.0" style="-fx-background-color: linear-gradient(to bottom right, #d4a64a, #606060); -fx-border-color: #dddddd;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <VBox prefHeight="140.0" prefWidth="220.0" style="-fx-background-color: linear-gradient(to bottom right, #75bdf1, #e0d1a4); -fx-border-color: #dddddd;" GridPane.columnIndex="2" GridPane.rowIndex="1" />
    </GridPane>

    <Label text="Encontre seu lugar ideal para morar e estudar!" alignment="CENTER" style="-fx-text-fill: #444;">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <HBox alignment="CENTER" spacing="16.0">
        <Button text="Login" onAction="#handleLoginButton" prefHeight="42.0" prefWidth="150.0" style="-fx-background-color: #d92828; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Cadastrar" onAction="#handleRegisterButton" prefHeight="42.0" prefWidth="150.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #777; -fx-border-radius: 8; -fx-text-fill: #333; -fx-font-weight: bold;"/>
    </HBox>
</VBox>
